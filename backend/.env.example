PORT=3001
NODE_ENV=development
STAFF_AUTH_REQUIRED=true
# One-line JSON string for Firebase Admin service account.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional for local dev. Use comma-separated origins in deployed environments.
CORS_ORIGINS=
# Optional Gemini integration. Leave blank to use local rule-based AI.
GEMINI_API_KEY=
# Optional Gemini model override.
GEMINI_MODEL=gemini-2.0-flash
